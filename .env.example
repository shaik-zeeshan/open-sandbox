SANDBOX_JWT_SECRET=change-me
# Optional: encrypt sandbox secret env values at rest with a raw 32-byte string
# or a base64-encoded 32-byte key.
# SANDBOX_SECRETS_KEY=0123456789abcdef0123456789abcdef
OPEN_SANDBOX_DATA_DIR=/var/lib/open-sandbox
# OPEN_SANDBOX_HTTP_PORT=3000
# SANDBOX_PUBLIC_BASE_URL=http://app.lvh.me:3000
# SANDBOX_PREVIEW_BASE_DOMAIN=preview.lvh.me
# SANDBOX_RUNTIME_MEMORY_LIMIT=4g
# SANDBOX_RUNTIME_CPU_LIMIT=2
# SANDBOX_RUNTIME_PIDS_LIMIT=512
# SANDBOX_MAINTENANCE_ARTIFACT_MAX_AGE=168h
# SANDBOX_MAINTENANCE_MISSING_SANDBOX_MAX_AGE=24h
